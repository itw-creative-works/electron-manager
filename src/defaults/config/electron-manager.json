{
  brand: {
    id: 'myapp',
    name: 'MyApp',
    url: 'https://myapp.example',
    contact: { email: 'support@myapp.example' },
    images: {
      brandmark: '',
      wordmark:  '',
      icon:      'src/assets/icons/icon.png',
    },
  },
  // App-level metadata — universal cross-platform fields. EM auto-derives sensible
  // defaults: `appId` ← `com.itwcreativeworks.<brand.id>`, `productName` ← `brand.name`,
  // `copyright` ← `© <year>, ITW Creative Works`. Override any of these explicitly only
  // if you must.
  //
  // `category` is a generic high-level category — EM maps it to per-platform values
  // (mac uses Apple's UTI strings, linux uses freedesktop categories). Allowed values:
  //   productivity (default) | developer-tools | utilities | media | social | network
  // Override the per-platform mapping in `targets.<plat>.category` if you need
  // something specific. See docs/installer-options.md for the full table.
  //
  // `copyright` accepts a `{YEAR}` token expanded at build time to the current year.
  // Default is `© {YEAR}, ITW Creative Works`. Set explicitly only to change the holder.
  app: {
    appId:           null,
    productName:     null,
    copyright:       null,                // null → `© {YEAR}, ITW Creative Works`
    category:        'productivity',
    languages:       ['en'],              // applied as mac.electronLanguages
    darkModeSupport: true,                // mac honors via NSRequiresAquaSystemAppearance; win/linux ignore
    // Icons are convention-only. Drop PNGs at:
    //   config/icons/global/<slot>.png       — universal default for all platforms
    //   config/icons/macos/<slot>.png        — macOS override (beats global)
    //   config/icons/windows/<slot>.png      — Windows override
    //   config/icons/linux/<slot>.png        — Linux override (otherwise falls back to global → windows)
    // Slots: icon, tray (mac+win+linux); dmg (mac-only).
    // Native size only — EM downscales @1x variants from your @2x source automatically.
    // macOS tray must be 32×32; EM renames the dist output to trayTemplate.png for the
    // OS dark-mode auto-inversion magic.
  },
  // Per-target install/distribution config. The keys here map directly to the same
  // electron-builder concepts (`mac.target`, `win.target`, `linux.target`) but EM owns
  // the actual target list (dmg+zip on mac, nsis on win, deb+AppImage on linux) so
  // auto-update keeps working — see docs/installer-options.md for why. Each block
  // exposes only the knobs that exist for that platform's target — no cross-platform
  // analog for any of these.
  targets: {
    mac: {
      arch: ['universal'],   // universal binary (x64 + arm64 lipo'd) — one .dmg/.zip for both
      // Entitlements override map. EM ships sensible defaults (allow-jit,
      // allow-unsigned-executable-memory, disable-library-validation, network.client/server,
      // files.user-selected.read-write, allow-dyld-environment-variables). To override:
      //   - Set a key to a value to add/replace it (boolean, string, or array per Apple's plist spec)
      //   - Set a key to `null` to remove it from EM's defaults
      // Output: dist/config/entitlements.mac.plist (auto-wired into electron-builder.yml).
      // Example: { 'com.apple.security.network.server': false, 'com.apple.security.device.audio-input': true }
      entitlements: {},
      // MAS (Mac App Store) — STUBBED. Config is parsed but not yet implemented;
      // setting `enabled: true` triggers an audit warning. Real implementation lands
      // in a future release. Reference plists from a working MAS-published Electron app
      // are archived at <em>/src/defaults/_mas/ for the eventual implementation.
      mas: {
        enabled:             false,
        provisioningProfile: null,
        entitlements:        null,
        entitlementsInherit: null,
      },
    },
    win: {
      arch: ['x64', 'ia32'],          // 64-bit + 32-bit (single multi-arch NSIS installer)
      oneClick:           true,        // no installer wizard, just installs immediately
      desktopShortcut:    true,
      startMenuShortcut:  true,
      runAfterFinish:     true,
      perMachine:         false,       // per-user install (required for oneClick:true)
      // Code-signing strategy. Picked at workflow time to drive runner selection +
      // job gating. See docs/signing.md.
      //   self-hosted (default) — sign with signtool against an EV USB token (typically
      //                           on an EM-managed self-hosted GH Actions runner)
      //   cloud                 — shell to a cloud signing provider's CLI (Azure /
      //                           SSL.com / DigiCert) — provider configured in cloud.provider
      //   local                 — skip CI signing; developer signs manually on their box
      signing: {
        strategy: 'self-hosted',
        cloud:    { provider: null, options: {} },
      },
    },
    linux: {
      arch: ['x64'],                   // amd64; ia32 is essentially extinct on Linux
      // Snap publishing — enabled by default. Adds a `snap` target to the linux build
      // and auto-publishes to the Snap Store on release. Requires SNAPCRAFT_STORE_CREDENTIALS
      // in your `.env` (run `snapcraft export-login -` locally to mint, then `mgr push-secrets`
      // flows it to GH Actions). Set enabled:false here to skip the snap target entirely.
      snap: {
        enabled:     true,
        confinement: 'strict',
        grade:       'stable',
        autoStart:   true,
        channels:    ['stable'],
      },
    },
  },
  // Auto-updater (electron-updater wrapper). Feed URL is auto-derived from `releases` (above).
  // Set `EM_DEV_UPDATE=available|unavailable|error` to simulate updates in dev.
  autoUpdate: {
    enabled:        true,
    channel:        'latest',
    autoDownload:   true,
    startupDelayMs: 10000,        // 10s after whenReady → first check
    intervalMs:     3600000,      // 1h between periodic checks (lib default is 60000 / 60s)
    maxAgeMs:       2592000000,   // 30d — once an update has been pending this long, force install
  },
  // Tray, menu, and context-menu are defined in JS files (full power, no DSL).
  // EM looks for them at the conventional paths:
  //   src/integrations/tray/index.js
  //   src/integrations/menu/index.js
  //   src/integrations/context-menu/index.js
  // To disable at runtime: call `manager.tray.disable()` / `manager.menu.disable()` /
  // `manager.contextMenu.disable()` from your main entry. Idempotent.

  // Startup behavior — two independent knobs.
  //
  // `mode` controls how the app launches when THE USER opens it directly:
  //   normal — main window appears, dock icon visible (typical app).
  //   hidden — packaged builds bake LSUIElement=true into Info.plist on macOS:
  //            zero dock bounce, no dock icon, not in Cmd+Tab. Tray + notifications
  //            + networking still work. Your main.js skips windows.create() at boot
  //            and surfaces UI later (typically from a tray click). When you do call
  //            windows.create('main'), EM auto-runs app.dock.show() so the dock icon
  //            appears alongside the window.
  //
  // `openAtLogin` controls auto-launch on OS login:
  //   enabled — register the app with the OS to auto-launch (default true).
  //   mode    — `hidden` (default) means at-login launches behave like `mode: 'hidden'`;
  //             `normal` means the at-login launch shows UI like a normal launch.
  //   The login-launch mode applies ONLY when the OS launches the app. User-direct
  //   launches always use `startup.mode` above. So a "normal" app can still start
  //   hidden at login and surface only when the user explicitly opens it.
  startup: {
    mode: 'normal',
    openAtLogin: {
      enabled: true,
      mode:    'hidden',
    },
  },
  // No `windows` block needed — EM no longer auto-creates windows. Your main.js
  // calls `manager.windows.create('main', { width: 1280, height: 800, ... })` when
  // you want UI to surface. Defaults baked in:
  //   main      → { width: 1024, height: 720, hideOnClose: true,  view: 'main' }
  //   any other → { width: 800,  height: 600, hideOnClose: false, view: name   }
  // Add a `windows: {}` block here only if you want to override defaults persistently.
  // Releases — public repo where built artifacts (and the auto-update feed) live.
  // The app repo can stay private; this one MUST be public for unauthenticated downloads + auto-updates.
  // owner defaults to the app repo's owner, so a single line `repo: 'update-server'` is usually all you need.
  // setup auto-creates this repo if it doesn't exist (uses GH_TOKEN).
  releases: {
    enabled: true,
    owner:   null,              // null = use app repo owner
    repo:    'update-server',
  },
  // Downloads — fixed-name mirror release. After every successful release, EM re-uploads the
  // versioned artifacts (MyApp-1.0.1.dmg) to a stable tag with stable names (MyApp-mac-arm64.dmg).
  // Marketing site links to https://github.com/<owner>/<repo>/releases/download/<tag>/<asset>
  // and that link never changes across versions.
  downloads: {
    enabled: true,
    owner:   null,              // null = use app repo owner
    repo:    'download-server',
    tag:     'installer',
  },
  // Deep links: scheme is automatically `<brand.id>://...`. Built-in routes:
  //   auth/token  → web-manager auth token handoff
  //   app/show    → manager.windows.show(query.window || 'main')
  //   app/quit    → app.quit()
  // Add custom routes at runtime: manager.deepLink.on('my-route', (ctx) => {...}) in main.

  sentry: {
    dsn: '',
  },

  // GA4 analytics. Measurement ID lives in config (not secret); the API secret
  // lives in `process.env.GOOGLE_ANALYTICS_SECRET` (matches BEM convention) so
  // it's not committed. Webpack's DefinePlugin bakes the secret into packaged
  // builds at build time so production apps don't need .env at runtime.
  // client_id / user_id are uuidv5(deviceId/firebaseUid, projectId-namespace)
  // so the same human gets unified events across desktop + web + backend.
  analytics: {
    // Presence-driven: set `providers.google.id` to `G-XXXXXXXXXX` to enable analytics.
    // Empty string = analytics disabled (matches BEM convention — no redundant enabled flag).
    providers: {
      google: {
        id: '',                               // 'G-XXXXXXXXXX' Measurement ID
      },
    },
  },

  // "Hot config" — JSON document fetched from the brand site so app behavior
  // can be flipped without shipping a new build (e.g. force-update gate, ads
  // toggle, default user agent strings, etc.). Default URL is derived as
  // `${brand.url}/data/resources/main.json` (legacy convention). Override the
  // path with `remoteConfig.url`. Polled at the same cadence as auto-updater
  // feed-check (default 1h). Disable via `enabled: false`.
  remoteConfig: {
    enabled: true,
    // url: 'https://brand.example/data/resources/main.json',   // default uses brand.url
  },

  // Payment — BEM-shaped so the same product catalog can be referenced from backend
  // + desktop. The schema enforces publishableKey shape when set; everything else is
  // freeform so apps can extend per their needs without EM caring. Leave empty until
  // you're ready to wire payments.
  payment: {
    processors: {
      stripe: { publishableKey: '' },
      paypal: { clientId:       '' },
    },
    products: [],
  },

  // Restart Manager — auxiliary helper app that handles relaunching this app on
  // our behalf via the `restart-manager://` URL scheme. EM auto-registers a few
  // seconds after launch, auto-unregisters on clean quit, and downloads + installs
  // restart-manager if missing (mac: signed .zip; windows: NSIS one-click; linux:
  // opens the .deb URL in the user's browser). Set false to disable entirely.
  // In dev mode it's silently skipped unless EM_RESTART_MANAGER_DEV=1.
  restartManager: {
    enabled: true,
  },

  // Firebase web SDK config. Flat shape — same key names BEM/BXM/web-manager all use.
  // Copy directly from Firebase Console → Project Settings → SDK setup (Config option).
  // Empty {} disables Firebase Auth in the renderer (web-manager-bridge logs a warn).
  firebaseConfig: {
    apiKey:            '',
    authDomain:        '',
    databaseURL:       '',
    projectId:         '',
    storageBucket:     '',
    messagingSenderId: '',
    appId:             '',
    measurementId:     '',
  },
}
