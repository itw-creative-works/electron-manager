{
  brand: {
    id: 'myapp',
    name: 'MyApp',
    url: 'https://myapp.example',
    contact: { email: 'support@myapp.example' },
    images: {
      brandmark: '',
      wordmark:  '',
      icon:      'src/assets/icons/icon.png',
    },
  },
  // App-level metadata. `appId` defaults to `com.itwcreativeworks.<brand.id>` if not set.
  // `productName` defaults to `brand.name`. Override either explicitly only if you must.
  app: {
    appId:       null,
    productName: null,
    copyright:   '© ITW Creative Works',
    // Icon overrides. Each is an optional project-relative or absolute path. Resolution
    // chain per slot, per platform: explicit config path → <projectRoot>/config/icons/<platform>/<slot>.png
    // → EM's bundled default. Linux follows the Windows chain; Windows tray falls back to
    // the Windows app icon if no tray-specific source resolves.
    // @2x variants are auto-discovered: if your @1x source is `foo.png`, EM looks for
    // `foo@2x.png` next to it and copies both. No need to specify @2x explicitly.
    icons: {
      // macOS
      appMac:    null,    // app icon source (electron-builder converts to .icns)
      trayMac:   null,    // 32x32 black template (auto-tints for menubar dark/light); @2x auto-paired
      dmgMac:    null,    // 540x380 DMG installer background; @2x auto-paired
      // Windows
      appWindows:  null,  // app icon source (electron-builder converts to .ico)
      trayWindows: null,  // optional; falls back to appWindows
      // Linux (optional; falls back to Windows resolution by default)
      appLinux:    null,
      trayLinux:   null,
    },
  },
  // mac.* keys override EM's defaults. `null` removes a default. Any key not in the defaults
  // is added to the merged set. See docs/signing.md for the full default list.
  // Example:  mac: { 'com.apple.security.cs.allow-jit': false, 'com.apple.security.network.client': true }
  entitlements: {
    mac: {},
  },
  // Auto-updater (electron-updater wrapper). Feed URL is auto-derived from `releases` (above).
  // Set `EM_DEV_UPDATE=available|unavailable|error` to simulate updates in dev.
  autoUpdate: {
    enabled:        true,
    channel:        'latest',
    autoDownload:   true,
    startupDelayMs: 10000,        // 10s after whenReady → first check
    intervalMs:     3600000,      // 1h between periodic checks (lib default is 60000 / 60s)
    maxAgeMs:       2592000000,   // 30d — once an update has been pending this long, force install
  },
  // Tray, menu, and context-menu are defined in JS files (full power, no DSL).
  // EM looks for them at the conventional paths:
  //   src/integrations/tray/index.js
  //   src/integrations/menu/index.js
  //   src/integrations/context-menu/index.js
  // To disable at runtime: call `manager.tray.disable()` / `manager.menu.disable()` /
  // `manager.contextMenu.disable()` from your main entry. Idempotent.

  // Startup behavior — two independent knobs.
  //
  // `mode` controls what happens when THE USER launches the app directly:
  //   normal     — main window shows immediately, dock icon visible (typical app)
  //   hidden     — no window auto-shown; consumer calls manager.windows.show() later. Dock icon
  //                still bounces briefly on macOS launch (unavoidable without LSUIElement).
  //   tray-only  — true agent app: no dock icon, no taskbar, no cmd-tab. Production builds bake
  //                LSUIElement=true into Info.plist for ZERO dock bounce on launch.
  //
  // `openAtLogin` controls auto-launch on OS login:
  //   enabled — register the app with the OS to auto-launch (default true)
  //   mode    — `hidden` (default) means at-login launches start without showing a window;
  //             `normal` means show the main window even on auto-launch.
  //   Login-launch mode applies ONLY when the OS launches the app. User-direct launches
  //   always use `startup.mode` above. So a "normal" app can still start hidden at login
  //   and surface only when the user explicitly opens it.
  startup: {
    mode: 'normal',
    openAtLogin: {
      enabled: true,
      mode:    'hidden',
    },
  },
  windows: {
    main:     { view: 'main',     width: 1024, height: 720, show: true,  hideOnClose: false },
    settings: { view: 'settings', width: 600,  height: 480, show: false, hideOnClose: true  },
    about:    { view: 'about',    width: 480,  height: 360, show: false, hideOnClose: true  },
  },
  signing: {
    windows: {
      strategy: 'self-hosted',
      cloud: { provider: null, options: {} },
    },
  },
  // Releases — public repo where built artifacts (and the auto-update feed) live.
  // The app repo can stay private; this one MUST be public for unauthenticated downloads + auto-updates.
  // owner defaults to the app repo's owner, so a single line `repo: 'update-server'` is usually all you need.
  // setup auto-creates this repo if it doesn't exist (uses GH_TOKEN).
  releases: {
    enabled: true,
    owner:   null,              // null = use app repo owner
    repo:    'update-server',
  },
  // Downloads — fixed-name mirror release. After every successful release, EM re-uploads the
  // versioned artifacts (MyApp-1.0.1.dmg) to a stable tag with stable names (MyApp-mac-arm64.dmg).
  // Marketing site links to https://github.com/<owner>/<repo>/releases/download/<tag>/<asset>
  // and that link never changes across versions.
  downloads: {
    enabled: true,
    owner:   null,              // null = use app repo owner
    repo:    'download-server',
    tag:     'installer',
  },
  // Deep links: scheme is automatically `<brand.id>://...`. Built-in routes:
  //   auth/token  → web-manager auth token handoff
  //   app/show    → manager.windows.show(query.window || 'main')
  //   app/quit    → app.quit()
  // Add custom routes at runtime: manager.deepLink.on('my-route', (ctx) => {...}) in main.

  sentry:         { dsn: '' },
  firebaseConfig: {},
  webManager:     {},
}
