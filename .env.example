# Local-only env for Electron Manager development and the Windows signing runner.
# Copy to .env and fill in. Never commit .env. Never package it.
#
# Files merge convention (matches BXM/UJM):
#   The "Default Values" section is overwritten on every `npx mgr setup`.
#   The "Custom Values" section is preserved verbatim — put your secrets there.
#   Existing values for keys that appear in both sections stay in their original section.
#   Values are normalized to double-quoted form on every merge (handles spaces / special chars).

# ========== Default Values ==========

# ─── GitHub ─────────────────────────────────────────────────────────────────
# Personal Access Token. electron-builder uses this to publish releases; EM scripts
# use it for cross-repo secret pushes etc. In CI, set as `secrets.GH_TOKEN` (not
# the auto-injected `secrets.GITHUB_TOKEN`, which is scoped only to the current repo).
# Required scopes for the Windows runner watcher (classic PAT): repo, workflow, admin:org.
# Note: manage_runners:org alone is NOT sufficient — the runner-registration-token API
# requires admin:org. Fine-grained tokens with "Self-hosted runners: write" can be used
# but must be issued per-org, breaking auto-discovery.
GH_TOKEN=""

# Optional — restrict `runner install` to a subset of admin orgs (comma or space-separated).
# Each org costs ~120 MB disk and one Windows service. If unset, ALL admin orgs are registered.
# Example: EM_RUNNER_ORGS="itw-creative-works,somiibo,proxifly"
EM_RUNNER_ORGS=""

# Optional — runner state directory. Defaults to <cwd>/.gh-runners. Set this if you want
# the per-org actions-runner installs (~120 MB each) on a separate disk.
EM_RUNNER_HOME=""

# ─── Backend Manager ────────────────────────────────────────────────────────
# Privileged key for calling admin endpoints on the dev/prod backend
# (e.g. minting test custom tokens, repo secret updates).
BACKEND_MANAGER_KEY=""

# ─── Test integration with Firebase / dev backend ───────────────────────────
# Path to a Firebase service-account JSON file. Used by integration tests to mint
# real custom tokens against the dev backend.
# Standard alias `GOOGLE_APPLICATION_CREDENTIALS` also accepted.
# If neither is set, integration tests skip cleanly with a "missing creds" reason.
EM_TEST_FIREBASE_ADMIN_KEY=""

# UID to mint test tokens for. Custom tokens auto-create the auth record on first use.
EM_TEST_USER_UID="em-test-user"

# Force integration tests to ALWAYS skip (e.g. on CI without creds).
EM_TEST_SKIP_INTEGRATION=""

# Surface electron stderr during tests
EM_TEST_DEBUG=""

# ─── macOS code signing + notarization ──────────────────────────────────────
# Cert paths typically point at `build/certs/<file>` (per-brand) or absolute paths.
# See docs/signing.md for the full setup walkthrough.
CSC_LINK=""
CSC_KEY_PASSWORD=""

# Notarization (App Store Connect API key)
APPLE_API_KEY=""
APPLE_API_KEY_ID=""
APPLE_API_ISSUER=""
APPLE_TEAM_ID=""

# ─── Windows signing — runner box / local signer (EV USB token) ─────────────
# Strategy (self-hosted | cloud | local) is configured in
# config/electron-manager.json (`signing.windows.strategy`). The vars below are
# the credentials/paths the runner machine uses to actually do the signing.
# These live on the machine that physically holds the EV USB token. On the
# self-hosted runner box this file IS the source of truth; consumer projects
# don't need to set them (they're delegated to the runner via CI).
#
# Leave WIN_EV_TOKEN_PATH empty if signtool can find your cert in the Windows
# user store automatically (typical for SafeNet-managed tokens). Otherwise set
# to a thumbprint, container path, or .pfx path.
WIN_EV_TOKEN_PATH=""
WIN_CSC_KEY_PASSWORD=""

# Optional — explicit signtool.exe path. Default: `signtool` on PATH (requires
# Windows SDK or VS Build Tools). Common SDK location:
# C:\Program Files (x86)\Windows Kits\10\bin\<sdk-version>\x64\signtool.exe
SIGNTOOL_PATH=""

# Optional — RFC 3161 timestamp server. Default: http://timestamp.sectigo.com
WIN_TIMESTAMP_URL=""

# ─── Windows signing — cloud provider (only when strategy=cloud) ────────────
# Azure Trusted Signing / SSL.com eSigner / DigiCert KeyLocker — provider-specific
# creds go in Custom Values below.
WIN_CLOUD_SIGN_PROVIDER=""

# ========== Custom Values ==========

# Anything below this line is yours and won't be touched by `npx mgr setup`.
