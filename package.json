{
  "name": "electron-manager",
  "version": "1.2.15",
  "description": "Electron Manager — all-in-one development framework for Electron apps",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./main": "./dist/main.js",
    "./renderer": "./dist/renderer.js",
    "./preload": "./dist/preload.js",
    "./build": "./dist/build.js",
    "./test": "./dist/test/index.js",
    "./hooks/notarize": "./dist/hooks/notarize.js",
    "./lib/app-state": "./dist/lib/app-state.js",
    "./lib/auto-updater": "./dist/lib/auto-updater.js",
    "./lib/context-menu": "./dist/lib/context-menu.js",
    "./lib/deep-link": "./dist/lib/deep-link.js",
    "./lib/ipc": "./dist/lib/ipc.js",
    "./lib/logger": "./dist/lib/logger.js",
    "./lib/logger-lite": "./dist/lib/logger-lite.js",
    "./lib/menu": "./dist/lib/menu.js",
    "./lib/protocol": "./dist/lib/protocol.js",
    "./lib/sentry": "./dist/lib/sentry/index.js",
    "./lib/startup": "./dist/lib/startup.js",
    "./lib/storage": "./dist/lib/storage.js",
    "./lib/templating": "./dist/lib/templating.js",
    "./lib/tray": "./dist/lib/tray.js",
    "./lib/web-manager-bridge": "./dist/lib/web-manager-bridge.js",
    "./lib/window-manager": "./dist/lib/window-manager.js"
  },
  "bin": {
    "em": "bin/electron-manager",
    "mgr": "bin/electron-manager",
    "electron-manager": "bin/electron-manager"
  },
  "files": [
    "bin",
    "dist",
    "scripts"
  ],
  "preparePackage": {
    "input": "./src",
    "output": "./dist",
    "type": "copy",
    "replace": {},
    "hooks": {}
  },
  "scripts": {
    "start": "npm run prepare:watch",
    "prepare": "node -e \"require('prepare-package')()\"",
    "prepare:watch": "node -e \"require('prepare-package/watch')()\"",
    "postinstall": "node scripts/sync-nvmrc.js",
    "test": "node ./bin/electron-manager test",
    "wm:prod": "npm uninstall web-manager && npm i web-manager@latest",
    "wm:local": "npm uninstall web-manager && npm i ../web-manager"
  },
  "projectScripts": {
    "start": "npx mgr clean && npx mgr setup && npm run gulp --",
    "gulp": "gulp --cwd ./ --gulpfile ./node_modules/electron-manager/dist/gulp/main.js",
    "build": "npx mgr clean && npx mgr setup && npx cross-env EM_BUILD_MODE=true npm run gulp -- build",
    "package": "npx mgr clean && npx mgr setup && npx cross-env EM_BUILD_MODE=true npm run gulp -- packageBuild",
    "publish": "npx cross-env EM_BUILD_MODE=true EM_IS_PUBLISH=true npm run gulp -- publish",
    "release": "npx mgr release",
    "release:local": "npx mgr clean && npx mgr setup && npx cross-env EM_BUILD_MODE=true EM_IS_PUBLISH=true npm run gulp -- publish",
    "postinstall": "node node_modules/electron-manager/scripts/sync-nvmrc.js",
    "test": "npx mgr test",
    "electron": "electron ."
  },
  "engines": {
    "node": "24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itw-creative-works/electron-manager.git"
  },
  "keywords": [
    "electron",
    "electron-builder",
    "electron-updater",
    "framework",
    "gulp",
    "webpack"
  ],
  "author": "ITW Creative Works",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/itw-creative-works/electron-manager/issues"
  },
  "homepage": "https://itwcreativeworks.com",
  "peerDependencies": {
    "electron": ">=41",
    "electron-builder": ">=26",
    "electron-store": ">=11",
    "gulp": "^5.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "firebase-admin": "^13.8.0",
    "prepare-package": "^2.1.0"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@sentry/electron": "^7.13.0",
    "chalk": "^5.6.2",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "electron-store": ">=11",
    "electron-updater": "^6.8.3",
    "fs-jetpack": "^5.1.0",
    "glob": "^13.0.6",
    "gulp-clean-css": "^4.3.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "libsodium-wrappers": "^0.8.4",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.5",
    "node-powertools": "^3.0.0",
    "npm-api": "^1.0.1",
    "plist": "^4.0.0",
    "sass": "^1.99.0",
    "through2": "^4.0.2",
    "web-manager": "^4.1.39",
    "webpack": "^5.106.2",
    "wonderful-fetch": "^2.0.5",
    "wonderful-version": "^1.3.2",
    "ws": "^8.20.0",
    "yargs": "^18.0.0"
  },
  "optionalDependencies": {
    "automately": "^1.0.5",
    "node-windows": "^1.0.0-beta.8"
  }
}
